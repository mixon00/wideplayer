{
  "name": "wideplayer-monorepo",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/extension"
  ],
  "scripts": {
    "build": "npm run build --workspace apps/web && npm run build --workspace apps/extension",
    "build:web": "npm run build --workspace apps/web",
    "build:extension": "npm run build --workspace apps/extension",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:extension": "npm run dev --workspace apps/extension",
    "typecheck:extension": "npm run typecheck --workspace apps/extension"
  }
}
